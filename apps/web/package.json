{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy:cesium": "mkdir -p public/cesium && cp node_modules/cesium/Build/Cesium/Cesium.js public/cesium && cp -R node_modules/cesium/Build/Cesium/Assets public/cesium && cp -R node_modules/cesium/Build/Cesium/ThirdParty public/cesium && cp -R node_modules/cesium/Build/Cesium/Widgets public/cesium && cp -R node_modules/cesium/Build/Cesium/Workers public/cesium",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "lint": "eslint",
    "postinstall": "npm run copy:cesium"
  },
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "cesium": "^1.139.0",
    "lightweight-charts": "^4.2.3",
    "mapbox-gl": "^3.19.0",
    "maplibre-gl": "^5.18.0",
    "next": "16.1.6",
    "postcss": "^8.5.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "satellite.js": "^6.0.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "framer-motion": "^12.23.24"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox__point-geometry": "^1.0.87",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.53.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  }
}
